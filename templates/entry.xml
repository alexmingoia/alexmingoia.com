<entry>
	<title>{{title}}</title>
	<link rel="alternate" type="text/html" href="{{permalink}}"/>
	<id>{{permalink}}</id>
	<published>{{published}}</published>
	<updated>{{updated}}</updated>
	<content type="html">
    {{content}}
	</content>
	<author>
		<name>{{blog_author}}</name>
	</author>
</entry>
